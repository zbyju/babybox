{
  "name": "babybox-panel",
  "version": "1.0.0",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "bunx vue-tsc --noEmit && bunx --bun vite build",
    "preview": "bunx --bun vite preview --port 5050",
    "test": "vitest run",
    "test:unit": "vitest --environment jsdom",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json --composite false",
    "lint": "bunx oxlint",
    "lint:fix": "bunx oxlint --fix",
    "format": "bunx oxfmt --write .",
    "format:check": "bunx oxfmt --check .",
    "echo": "echo 'Hello from panel'"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "howler": "^2.2.3",
    "lodash": "^4.17.21",
    "moment": "^2.29.3",
    "pinia": "^2.3.1",
    "vite": "^5.4.21",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4",
    "vue-tsc": "^2.2.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/howler": "^2.2.7",
    "@types/jsdom": "^16.2.14",
    "@types/lodash": "^4.14.182",
    "@types/node": "^20.19.37",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/tsconfig": "^0.1.3",
    "jsdom": "^26.1.0",
    "stylus": "^0.57.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
