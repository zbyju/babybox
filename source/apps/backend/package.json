{
  "name": "babybox-panel-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "keywords": [],
  "author": "",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "lint": "bunx oxlint",
    "lint:fix": "bunx oxlint --fix",
    "format": "bunx oxfmt --write .",
    "format:check": "bunx oxfmt --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:postman": "newman run ./src/routes/__postman__/babybox-panel.postman_collection.json -e ./src/routes/__postman__/BabyboxPanel.postman_environment.json",
    "build": "bun build src/index.ts --outdir dist --target node",
    "typecheck": "tsc --noEmit",
    "win:build": "bun build src/index.ts --outdir dist --target node",
    "echo": "echo 'Hello from babybox panel backend'"
  },
  "devDependencies": {
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.13",
    "@types/lodash.merge": "^4.6.9",
    "@types/morgan": "^1.9.3",
    "@types/node": "^20.19.37",
    "newman": "^5.3.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "lodash.merge": "^4.6.2",
    "lowdb": "3.0.0",
    "moment": "^2.29.3",
    "morgan": "^1.10.0",
    "open": "^10.2.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  }
}
