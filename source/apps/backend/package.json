{
  "name": "babybox-panel-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "keywords": [],
  "author": "",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "lint": "eslint --fix --ext .js,.ts .",
    "format": "prettier --ignore-path .gitignore --write \"**/*.+(js|ts|json)\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:postman": "newman run ./src/routes/__postman__/babybox-panel.postman_collection.json -e ./src/routes/__postman__/BabyboxPanel.postman_environment.json",
    "build": "bun build src/index.ts --outdir dist --target node",
    "typecheck": "tsc --noEmit",
    "win:build": "bun build src/index.ts --outdir dist --target node",
    "echo": "echo 'Hello from babybox panel backend'"
  },
  "devDependencies": {
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.13",
    "@types/jest": "^28.1.6",
    "@types/lodash.merge": "^4.6.9",
    "@types/morgan": "^1.9.3",
    "@types/node": "^20.19.37",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "coveralls": "^3.1.1",
    "eslint": "^8.20.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-simple-import-sort": "^7.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^28.1.3",
    "newman": "^5.3.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "ts-jest": "^28.0.7",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "lodash.merge": "^4.6.2",
    "lowdb": "3.0.0",
    "moment": "^2.29.3",
    "morgan": "^1.10.0",
    "open": "^10.2.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  }
}
