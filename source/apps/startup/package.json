{
  "name": "startup",
  "version": "1.0.0",
  "type": "module",
  "description": "Small app to update and startup the app",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --loader ts-node/esm src/index.ts",
    "dev:install": "nodemon --loader ts-node/esm src/index.ts -- --install",
    "start": "node dist/index.js",
    "start:install": "node dist/index.js --install",
    "typecheck": "tsc --noEmit"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/fs-extra": "^11.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.21.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-simple-import-sort": "^7.0.0",
    "eslint-plugin-unused-imports": "^2.0.0",
    "jest": "^28.1.3",
    "prettier": "^2.7.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "fs-extra": "^10.1.0",
    "moment": "^2.29.3",
    "sudo-prompt": "^9.2.1",
    "winston": "^3.8.1"
  }
}
