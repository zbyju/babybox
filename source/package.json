{
  "name": "babybox-mono",
  "version": "1.0.0",
  "description": "",
  "author": "",
  "keywords": [],
  "packageManager": "bun@1.2.21",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:backend": "turbo dev --filter=babybox-panel-backend",
    "dev:panel": "turbo dev --filter=babybox-panel",
    "stop": "pm2 delete all",
    "start:main": "pm2 start bun --name babybox -- apps/backend/src/index.ts",
    "build": "turbo build",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "clean": "turbo clean && rm -rf node_modules bun.lock",
    "echo": "echo test"
  },
  "devDependencies": {
    "@types/cors": "2.8.12",
    "@types/express": "4.17.13",
    "@types/lodash.merge": "4.6.7",
    "@types/node": "20.19.37",
    "ts-node": "10.9.1",
    "turbo": "2.8.20",
    "typescript": "5.9.3"
  }
}
